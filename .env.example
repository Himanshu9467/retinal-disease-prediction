# JWT security
# Required: generate a strong secret before running the backend.
# PowerShell: [guid]::NewGuid().ToString() + [guid]::NewGuid().ToString()
# Python: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace_with_your_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Application
APP_ENV=development
LOG_LEVEL=INFO
RETINAL_REJECTION_ENABLED=1
CVD_DB_PATH=./database/cvd_system.db

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE=http://127.0.0.1:8001

# Model configuration
MODEL_NAME=efficientnet
IMG_SIZE=300
MODEL_REGISTRY_DIR=research_training_outputs2

# Demo users (optional, set SEED_DEMO_USERS=1)
SEED_DEMO_USERS=0
DEMO_DOCTOR_PASSWORD=
DEMO_STAFF_PASSWORD=
